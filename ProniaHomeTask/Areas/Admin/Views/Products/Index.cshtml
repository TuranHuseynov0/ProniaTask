@model IEnumerable<ProniaHomeTask.Models.Product>
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-secondary fw-bold">Məhsulların Siyahısı</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Yeni Yarat
        </a>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-striped align-middle mb-0 bg-white">
            <thead class="table-dark">
                <tr>
                    <th scope="col" class="ps-3">@Html.DisplayNameFor(model => model.Name)</th>
                    <th scope="col">@Html.DisplayNameFor(model => model.Price)</th>
                    <th scope="col">@Html.DisplayNameFor(model => model.Description)</th>
                    <th scope="col">Şəkil</th>
                    <th scope="col" class="text-end pe-3">Əməliyyatlar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-semibold ps-3">
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            <span class="badge bg-light text-dark border px-2 py-1">
                                $@Html.DisplayFor(modelItem => item.Price)
                            </span>
                        </td>
                        <td class="text-muted text-truncate" style="max-width: 250px;">
                            @Html.DisplayFor(modelItem => item.Description)
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImgUrl))
                            {
                                <img src="~/@item.ImgUrl" alt="@item.Name" class="img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;" />
                            }
                            else
                            {
                                <span class="text-muted small">Şəkil yoxdur</span>
                            }
                        </td>
                        <td class="text-end pe-3">
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary">
                                    Düzəliş
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">
                                    Ətraflı
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">
                                    Sil
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>