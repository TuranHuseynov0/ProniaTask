@model ProniaHomeTask.Models.Product

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-secondary fw-bold">Məhsul Yarat</h2>
        <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left-circle me-1"></i> Siyahıya Qayıt
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded">
        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0 fw-semibold">
                <i class="bi bi-plus-circle me-2"></i>Yeni Məhsul Məlumatları
            </h5>
        </div>

        <div class="card-body p-4 bg-white">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-semibold text-muted">@Html.DisplayNameFor(model => model.Name)</label>
                        <input asp-for="Name" class="form-control" placeholder="Məhsulun adını daxil edin" />
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label fw-semibold text-muted">@Html.DisplayNameFor(model => model.Price)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-dark border">$</span>
                            <input asp-for="Price" class="form-control" placeholder="0.00" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label fw-semibold text-muted">@Html.DisplayNameFor(model => model.CategoryId)</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- Kateqoriya seçin --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="ImageUpload" class="form-label fw-semibold text-muted">@Html.DisplayNameFor(model => model.ImageUpload)</label>
                        <input asp-for="ImageUpload" class="form-control" type="file" accept="image/*" />
                        <span asp-validation-for="ImageUpload" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold text-muted">@Html.DisplayNameFor(model => model.Description)</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Məhsul haqqında qısa təsvir yazın..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                    </div>
                </div>

                <hr class="my-4 text-muted" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light px-4 border">Ləğv Et</a>
                    <button type="submit" class="btn btn-success px-5 shadow-sm">
                        <i class="bi bi-check-circle me-1"></i> Yarat
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>